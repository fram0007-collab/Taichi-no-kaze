{
  "version": 2,
  "rewrites": [
    { "source": "/api/predictions/active",       "destination": "/api/predictions_active" },
    { "source": "/api/predictions/zone/:zoneId", "destination": "/api/predictions_zone" },
    { "source": "/api/zone-status/all",          "destination": "/api/zone_status_all" },
    { "source": "/api/safe-zones",               "destination": "/api/safe_zones" },
    { "source": "/api/admin/status",             "destination": "/api/admin_status" },
    { "source": "/api/alerts/history",           "destination": "/api/alerts_history" },
    { "source": "/api/dashboard/summary",        "destination": "/api/dashboard_summary" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "x-vercel-skip-toolbar", "value": "1" }
      ]
    }
  ]
}
