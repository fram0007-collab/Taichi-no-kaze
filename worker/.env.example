# Copy to .env and fill in real values
DATABASE_URL=postgresql://USER:PASSWORD@host.supabase.com:5432/postgres?sslmode=require
TOMTOM_API_KEY=your_tomtom_key_here
TRAFFIC_PROVIDER=tomtom
ADMIN_PASSWORD=choose_a_strong_password
DISPLAY_ALL_EARTHQUAKES=false
MOCK_SERVER_URL=
CRON_SECRET=generate_with: python -c "import secrets; print(secrets.token_urlsafe(32))"
