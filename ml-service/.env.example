# Same database as backend/worker (read-only queries; no +asyncpg here, sync driver)
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-....supabase.com:6543/postgres?sslmode=require

# Shared secret required in the "X-Train-Secret" header to trigger /train.
# Pick any string, put the same one wherever you call /train from (e.g. GitHub Actions cron).
TRAIN_SECRET=change_me

# How far ahead we're predicting alerts, in hours. Must match what train.py was run with.
PREDICTION_HORIZON_HOURS=3
